<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-content">
      <text class="title">高校竞赛中心</text>
      <text class="subtitle">College Competition Hub</text>
    </view>
    <view class="search-bar">
      <icon type="search" size="16" color="#fff" class="search-icon" />
      <input placeholder="搜索竞赛名称..." placeholder-class="placeholder" bindinput="onSearch" />
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view scroll-y class="content-scroll">
    <!-- 首页内容 -->
    <block wx:if="{{activeTab === 'home'}}">
      <view class="recommend-card" bindtap="showRecommendation">
        <view class="recommend-icon">✨</view>
        <view class="recommend-info">
          <text class="recommend-title">智能推荐竞赛</text>
          <text class="recommend-desc">目标：{{userGoal}} | 专业：{{userMajor}}</text>
        </view>
      </view>

      <view class="section-title">
        <text>热门竞赛推荐</text>
        <view class="filter-btn" bindtap="openFilter">筛选分类</view>
      </view>

      <view class="comp-list">
        <view wx:for="{{filteredCompetitions}}" wx:key="id" class="comp-card" bindtap="viewDetail" data-id="{{item.id}}">
          <view class="comp-header">
            <text class="comp-name">{{item.name}}</text>
            <text class="comp-level">{{item.level}}</text>
          </view>
          <view class="comp-deadline">
            <icon type="waiting" size="12" color="#ff4d4f" />
            <text>报名截止: 还剩 {{item.daysLeft}} 天</text>
          </view>
          <view class="comp-tags">
            <text class="tag">{{item.category}}</text>
            <text class="tag" wx:for="{{item.techStack}}" wx:for-item="tech" wx:key="*this">{{tech}}</text>
          </view>
          <view class="comp-actions">
            <button class="btn-outline" catchtap="toggleFollow" data-id="{{item.id}}">订阅提醒</button>
            <button class="btn-primary" catchtap="register" data-url="{{item.registrationUrl}}">立即报名</button>
          </view>
        </view>
      </view>
    </block>

    <!-- 卷王榜内容 -->
    <block wx:if="{{activeTab === 'hall'}}">
      <view class="hall-header">
        <text class="hall-title">优秀获奖作品展示</text>
        <text class="hall-subtitle">向优秀的学长学姐学习经验</text>
      </view>
      <view class="hall-list">
        <view wx:for="{{hallOfFame}}" wx:key="id" class="hall-card">
          <view class="hall-card-header">
            <text class="project-name">{{item.projectName}}</text>
            <text class="award-badge">{{item.awardLevel}}</text>
          </view>
          <view class="hall-details">
            <text class="detail-text">专业：{{item.major}}</text>
            <text class="detail-text">年份：{{item.year}}</text>
          </view>
          <view class="hall-section">
            <text class="section-label">团队介绍</text>
            <text class="section-content">{{item.teamIntro}}</text>
          </view>
          <view class="hall-section">
            <text class="section-label">成功秘诀</text>
            <text class="section-content highlight">{{item.keyToSuccess}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 个人中心内容 -->
    <block wx:if="{{activeTab === 'profile'}}">
      <view class="profile-header">
        <view class="avatar">{{userName[0]}}</view>
        <view class="user-info">
          <text class="user-name">{{userName}}</text>
          <text class="user-meta">{{userMajor}} | {{userGrade}}</text>
        </view>
      </view>
      
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-num">{{followedIds.length}}</text>
          <text class="stat-label">已关注</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{registeredIds.length}}</text>
          <text class="stat-label">已报名</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">2</text>
          <text class="stat-label">获奖记录</text>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-bar-item {{activeTab === 'home' ? 'active' : ''}}" bindtap="switchTab" data-tab="home">
      <text class="tab-icon">🏠</text>
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-bar-item {{activeTab === 'hall' ? 'active' : ''}}" bindtap="switchTab" data-tab="hall">
      <text class="tab-icon">🏆</text>
      <text class="tab-text">卷王榜</text>
    </view>
    <view class="tab-bar-item {{activeTab === 'profile' ? 'active' : ''}}" bindtap="switchTab" data-tab="profile">
      <text class="tab-icon">👤</text>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
