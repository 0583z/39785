/* pages/index/index.wxss */
.header {
  background-color: #003366;
  padding: 60rpx 40rpx 40rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.header-content {
  margin-bottom: 30rpx;
}

.title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
}

.search-bar {
  background-color: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 15rpx 25rpx;
}

.search-icon {
  margin-right: 15rpx;
}

.search-bar input {
  color: #ffffff;
  font-size: 26rpx;
  flex: 1;
}

.placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.tabs {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #003366;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #003366;
}

.content-scroll {
  flex: 1;
  padding: 30rpx;
}

.recommend-card {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border: 1rpx solid #fed7aa;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.recommend-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.recommend-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.recommend-desc {
  font-size: 22rpx;
  color: #666666;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title text {
  font-size: 30rpx;
  font-weight: bold;
}

.filter-btn {
  font-size: 24rpx;
  color: #666666;
  border: 1rpx solid #e8e8e8;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.comp-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.comp-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.comp-name {
  font-size: 30rpx;
  font-weight: bold;
  flex: 1;
  margin-right: 20rpx;
}

.comp-level {
  font-size: 20rpx;
  background-color: rgba(0, 51, 102, 0.1);
  color: #003366;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  height: fit-content;
}

.comp-deadline {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-bottom: 20rpx;
}

.comp-deadline text {
  margin-left: 10rpx;
}

.comp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.tag {
  font-size: 20rpx;
  color: #666666;
  background-color: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.comp-actions {
  display: flex;
  gap: 20rpx;
}

.btn-outline, .btn-primary {
  flex: 1;
  font-size: 24rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 16rpx;
}

.btn-outline {
  background-color: transparent;
  border: 1rpx solid #003366;
  color: #003366;
}

.btn-primary {
  background-color: #003366;
  color: #ffffff;
}

/* 个人中心样式 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 40rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: #003366;
  color: #ffffff;
  border-radius: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 30rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.user-meta {
  font-size: 24rpx;
  color: #666666;
}

.stats-grid {
  display: flex;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid #f0f2f5;
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #003366;
}

.stat-label {
  font-size: 20rpx;
  color: #666666;
}

/* 卷王榜样式 */
.hall-header {
  padding: 20rpx 0 40rpx;
}

.hall-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.hall-subtitle {
  font-size: 22rpx;
  color: #666666;
}

.hall-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.hall-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.project-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #003366;
  flex: 1;
  margin-right: 20rpx;
}

.award-badge {
  font-size: 18rpx;
  background-color: #fff7ed;
  color: #c2410c;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid #fed7aa;
}

.hall-details {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.detail-text {
  font-size: 20rpx;
  color: #666666;
}

.hall-section {
  margin-top: 15rpx;
}

.section-label {
  font-size: 20rpx;
  font-weight: bold;
  color: #999999;
  display: block;
  margin-bottom: 5rpx;
}

.section-content {
  font-size: 24rpx;
  color: #333333;
  line-height: 1.5;
}

.section-content.highlight {
  color: #003366;
  font-style: italic;
}

/* 底部导航栏样式 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  border-top: 1rpx solid #e8e8e8;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #666666;
}

.tab-bar-item.active .tab-text {
  color: #003366;
  font-weight: bold;
}
