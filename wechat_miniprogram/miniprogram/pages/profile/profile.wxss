.profile-container {
  padding: 30rpx;
}

/* 头部卡片 */
.header-card {
  background: #fff;
  padding: 40rpx;
  border-radius: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #003366;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  font-weight: bold;
}

.info-text {
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 36rpx;
  font-bold: bold;
  color: #1a1a1a;
}

.sub {
  font-size: 24rpx;
  color: #8e9299;
  margin-top: 8rpx;
}

.edit-btn {
  font-size: 24rpx;
  color: #003366;
  background: #f0f4f8;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 30rpx;
}

.stat-item {
  background: #fff;
  padding: 30rpx;
  border-radius: 24rpx;
  text-align: center;
}

.num {
  font-size: 36rpx;
  font-weight: bold;
  color: #003366;
  display: block;
}

.label {
  font-size: 20rpx;
  color: #8e9299;
  margin-top: 4rpx;
}

/* 作品集卡片 */
.portfolio-card {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #003366, #004080);
  padding: 50rpx 40rpx;
  border-radius: 40rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(0,51,102,0.2);
}

.p-title {
  color: #D4AF37;
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.p-desc {
  color: rgba(255,255,255,0.7);
  font-size: 22rpx;
  margin-top: 10rpx;
  display: block;
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  border-radius: 32rpx;
  margin-top: 30rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 2rpx solid #f2f2f2;
}

.menu-item.no-border {
  border-bottom: none;
}

.m-label {
  font-size: 28rpx;
  color: #333;
}

.m-value {
  font-size: 26rpx;
  color: #003366;
  font-weight: bold;
}

.m-arrow {
  color: #ccc;
  font-size: 28rpx;
}
