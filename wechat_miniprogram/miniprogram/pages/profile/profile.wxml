<view className="profile-container">
  <!-- 头部信息 -->
  <view class="header-card">
    <view class="user-info">
      <view class="avatar">{{userName[0]}}</view>
      <view class="info-text">
        <text class="name">{{userName}}</text>
        <text class="sub">{{userMajor}} | {{userGrade}}</text>
      </view>
    </view>
    <view class="edit-btn" bindtap="onEditProfile">编辑</view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-grid">
    <view class="stat-item">
      <text class="num">{{stats.followed}}</text>
      <text class="label">已关注</text>
    </view>
    <view class="stat-item">
      <text class="num">{{stats.registered}}</text>
      <text class="label">已报名</text>
    </view>
    <view class="stat-item">
      <text class="num">{{stats.awards}}</text>
      <text class="label">获奖记录</text>
    </view>
  </view>

  <!-- 作品集入口 -->
  <view class="portfolio-card">
    <text class="p-title">💼 一键生成作品集</text>
    <text class="p-desc">高光荣誉 × 技能矩阵 × 核心项目</text>
  </view>

  <!-- 列表设置 -->
  <view class="menu-list">
    <view class="menu-item">
      <text class="m-label">我的专业推荐</text>
      <text class="m-value">{{userMajor}}</text>
    </view>
    <view class="menu-item">
      <text class="m-label">奋斗目标</text>
      <text class="m-value">{{userGoal}}</text>
    </view>
    <view class="menu-item no-border">
      <text class="m-label">我的荣誉记录</text>
      <text class="m-arrow">></text>
    </view>
  </view>
</view>
