.container {
  background-color: #F7F8FA;
  min-height: 100vh;
}

.header {
  background-color: #003366;
  padding: 60rpx 40rpx 40rpx;
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
}

.title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  margin-top: 10rpx;
  display: block;
}

.search-bar {
  background-color: rgba(255, 255, 255, 0.15);
  margin-top: 40rpx;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.search-bar input {
  color: #ffffff;
  font-size: 28rpx;
  margin-left: 20rpx;
  flex: 1;
}

.filter-scroll {
  white-space: nowrap;
  padding: 30rpx 40rpx;
  display: flex;
}

.filter-item {
  display: inline-block;
  padding: 10rpx 30rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
  border: 1rpx solid #eee;
}

.filter-item.active {
  background-color: #003366;
  color: #ffffff;
  border-color: #003366;
}

.list-section {
  padding: 0 40rpx 40rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.badge {
  background-color: rgba(0, 51, 102, 0.1);
  color: #003366;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.countdown {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.countdown text {
  margin-left: 8rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #003366;
  margin-top: 20rpx;
}

.tech-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 20rpx;
  color: #666;
  border: 1rpx solid #eee;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.prob-box {
  background-color: #FFF7F0;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.prob-text {
  font-size: 24rpx;
  color: #FF6600;
  font-weight: 500;
}

.card-footer {
  display: flex;
  margin-top: 30rpx;
  gap: 20rpx;
}

.card-footer button {
  flex: 1;
  font-size: 28rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 12rpx;
}

.btn-sub {
  background-color: transparent;
  color: #003366;
  border: 1rpx solid rgba(0, 51, 102, 0.2);
}

.btn-reg {
  background-color: #003366;
  color: #ffffff;
}
